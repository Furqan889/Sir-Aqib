<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0a0a0f;
            color: #fff;
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 260px;
            background: #000;
            padding: 30px 20px;
            border-right: 1px solid rgba(255,255,255,0.1);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }
        .sidebar-header {
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar-header h2 {
            font-family: 'Orbitron', sans-serif;
            background: linear-gradient(135deg, #00d4ff 0%, #7b2cbf 100%);
            /* -webkit-background-clip: text; */
            -webkit-text-fill-color: transparent;
            font-size: 1.3rem;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            transition: all 0.3s;
        }
        .nav-item:hover, .nav-item.active {
            background: rgba(0, 212, 255, 0.1);
            color: #00d4ff;
        }
        .nav-item i {
            width: 20px;
        }
        .main-content {
            flex: 1;
            margin-left: 260px;
            padding: 30px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .header h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .logout-btn {
            padding: 8px 16px;
            background: rgba(255, 0, 110, 0.2);
            color: #ff006e;
            border: 1px solid #ff006e;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.9rem;
        }
        .message-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
            transition: all 0.3s;
        }
        .message-card:hover {
            border-color: rgba(0, 212, 255, 0.3);
        }
        .message-card.unread {
            border-left: 4px solid #ff006e;
        }
        .message-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 15px;
        }
        .sender-info h3 {
            font-size: 1.2rem;
            margin-bottom: 5px;
        }
        .sender-info p {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
        }
        .meta {
            text-align: right;
            color: rgba(255,255,255,0.4);
            font-size: 0.85rem;
        }
        .message-body {
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            padding: 20px;
            margin: 15px 0;
            line-height: 1.6;
            white-space: pre-wrap;
        }
        .message-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-mark {
            background: rgba(57, 255, 20, 0.2);
            color: #39ff14;
            border: 1px solid #39ff14;
        }
        .btn-delete {
            background: rgba(255, 0, 110, 0.2);
            color: #ff006e;
            border: 1px solid #ff006e;
        }
        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .badge-new {
            background: rgba(255, 0, 110, 0.2);
            color: #ff006e;
        }
        .badge-read {
            background: rgba(57, 255, 255, 0.2);
            color: #00d4ff;
        }
        .pagination {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
        }
        .page-btn {
            padding: 8px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
        }
        .page-btn.active {
            background: #00d4ff;
            color: #000;
        }
        .empty-state {
            text-align: center;
            padding: 60px;
            color: rgba(255,255,255,0.4);
        }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>⚡ ADMIN</h2>
        </div>
        <nav>
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-home"></i>
                Dashboard
            </a>
            <a href="/admin/messages" class="nav-item active">
                <i class="fas fa-envelope"></i>
                All Messages
            </a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="header">
            <h1>All Messages (<%= total %>)</h1>
            <div class="user-info">
                <span>Welcome, <%= admin.username %></span>
                <a href="/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        <% if (messages && messages.length > 0) { %>
            <% messages.forEach(msg => { %>
                <div class="message-card <%= msg.read ? '' : 'unread' %>">
                    <div class="message-header">
                        <div class="sender-info">
                            <h3><i class="fas fa-user"></i> <%= msg.fullName %></h3>
                            <p><i class="fas fa-envelope"></i> <%= msg.email || 'No email provided' %></p>
                        </div>
                        <div class="meta">
                            <span class="badge <%= msg.read ? 'badge-read' : 'badge-new' %>">
                                <%= msg.read ? 'Read' : 'New' %>
                            </span>
                            <div style="margin-top: 8px;">
                                <%= new Date(msg.createdAt).toLocaleString('en-PK', { timeZone: 'Asia/Karachi' }) %>
                            </div>
                        </div>
                    </div>
                    
                    <div class="message-body">
                        <%= msg.message %>
                    </div>

                    <div class="message-actions">
                        <% if (!msg.read) { %>
                            <form action="/admin/messages/<%= msg._id %>/read" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-mark">
                                    <i class="fas fa-check"></i> Mark as Read
                                </button>
                            </form>
                        <% } %>
                        <form action="/admin/messages/<%= msg._id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Delete this message permanently?')">
                            <button type="submit" class="btn btn-delete">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin/messages?page=<%= i %>" class="page-btn <%= currentPage === i ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-inbox" style="font-size: 4rem; margin-bottom: 20px; opacity: 0.3;"></i>
                <h3>No messages yet</h3>
                <p>Messages from your portfolio contact form will appear here</p>
            </div>
        <% } %>
    </main>
</body>
</html>
